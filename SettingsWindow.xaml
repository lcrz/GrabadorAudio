<Window x:Class="GrabadorAudio.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración" Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#18181b" Foreground="#fafafa"
        ResizeMode="NoResize" WindowStyle="ToolWindow">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configuración" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Atajo para Captura de Pantalla:" FontSize="14" Margin="0,0,0,10" Foreground="#a1a1aa"/>

        <Border Grid.Row="2" Background="#27272a" BorderBrush="#3f3f46" BorderThickness="1" CornerRadius="4" Padding="10">
            <StackPanel>
                <TextBlock x:Name="CurrentHotkeyText" Text="Ctrl + Shift + S" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <Button x:Name="RecordHotkeyBtn" Content="Cambiar Atajo" Click="RecordHotkeyBtn_Click" 
                        Background="#4f46e5" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="Carpeta de Grabaciones:" FontSize="14" Margin="0,0,0,10" Foreground="#a1a1aa"/>

        <Border Grid.Row="5" Background="#27272a" BorderBrush="#3f3f46" BorderThickness="1" CornerRadius="4" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderPathTextBox" Text="" Background="#1c1c1f" Foreground="#fafafa" 
                         BorderBrush="#3f3f46" BorderThickness="1" Padding="8,4" IsReadOnly="True" VerticalContentAlignment="Center" 
                         FontSize="12" Margin="0,0,10,0" Height="28"/>
                <Button Grid.Column="1" x:Name="BrowseFolderBtn" Content="Examinar..." Click="BrowseFolderBtn_Click" 
                        Background="#4f46e5" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Height="28">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <TextBlock Grid.Row="6" x:Name="ListeningText" Text="Presiona la nueva combinación de teclas..." 
                   Foreground="#f59e0b" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cerrar" Click="CloseBtn_Click" 
                    Background="#3f3f46" Foreground="White" BorderThickness="0" Padding="15,8" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
