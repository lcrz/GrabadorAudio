<Window x:Class="GrabadorAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Grabador de Audio Pro" Height="620" Width="920"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo General de Botón Redondeado -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#312e81"/>
            <Setter Property="Foreground" Value="#fafafa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" SnapsToDevicePixels="True"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4338ca"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3730a3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#27272a"/>
                                <Setter Property="Foreground" Value="#71717a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Botón Secundario (Gris) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#e4e4e7"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" SnapsToDevicePixels="True"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3f3f46"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#52525b"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#52525b"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#18181b"/>
                                <Setter Property="Foreground" Value="#52525b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo del Botón de Grabar (Rojo Circular) -->
        <Style x:Key="RecordButton" TargetType="Button">
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="glow" Fill="#f43f5e" Opacity="0" Margin="-4">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse x:Name="circle" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="#e11d48"/>
                                <Setter TargetName="glow" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="#be123c"/>
                                <Setter TargetName="glow" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="circle" Property="Fill" Value="#27272a"/>
                                <Setter Property="Foreground" Value="#52525b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Barra de Volumen LED -->
        <Style x:Key="VolumeProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#18181b"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                            <Border x:Name="PART_Indicator" CornerRadius="5" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#22c55e" Offset="0.0"/>
                                        <GradientStop Color="#eab308" Offset="0.7"/>
                                        <GradientStop Color="#ef4444" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para ítems de la lista de grabaciones -->
        <Style x:Key="RecordItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" BorderThickness="1" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#27272a"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3f3f46"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#312e81"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4f46e5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de Slider Moderno (Vía ControlTemplate) -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Background" Value="#27272a"/>
            <Setter Property="Foreground" Value="#6366f1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Track Background -->
                            <Border x:Name="TrackBackground" 
                                    Grid.Row="1" 
                                    Background="{TemplateBinding Background}" 
                                    Height="4" 
                                    CornerRadius="2" 
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Foreground}" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Height="4" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ellipse" 
                                                         Fill="#fafafa" 
                                                         Stroke="{TemplateBinding Foreground}" 
                                                         StrokeThickness="2" 
                                                         Width="12" 
                                                         Height="12"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ellipse" Property="Fill" Value="#ffffff"/>
                                                        <Setter TargetName="ellipse" Property="Width" Value="14"/>
                                                        <Setter TargetName="ellipse" Property="Height" Value="14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de ComboBox Completamente Personalizado Dark -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1c1c1f"/>
            <Setter Property="Foreground" Value="#fafafa"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="true">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Botón de fondo y borde -->
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.ColumnSpan="2" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="templateRoot" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="6" 
                                                SnapsToDevicePixels="true">
                                            <!-- Flecha del desplegable -->
                                            <Grid HorizontalAlignment="Right" Width="30">
                                                <Path x:Name="Arrow" 
                                                      Data="M0,0 L4,4 L8,0 Z" 
                                                      Fill="#a1a1aa" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#27272a"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#52525b"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#ffffff"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#27272a"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#6366f1"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#ffffff"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#141415"/>
                                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#1c1c1f"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#52525b"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Contenido del item seleccionado -->
                            <ContentPresenter x:Name="contentPresenter" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              IsHitTestVisible="false" 
                                              Margin="{TemplateBinding Padding}" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                            <!-- Popup desplegable -->
                            <Popup x:Name="PART_Popup" 
                                   AllowsTransparency="true" 
                                   Grid.ColumnSpan="2" 
                                   IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Placement="Bottom" 
                                   Margin="1"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" 
                                        Background="#141415" 
                                        BorderBrush="#3f3f46" 
                                        BorderThickness="1" 
                                        CornerRadius="6"
                                        Margin="0,2,0,0"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" SnapsToDevicePixels="true">
                                        <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">
                                            <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">
                                                <Rectangle x:Name="opaqueRect" 
                                                           Fill="{Binding Background, ElementName=dropDownBorder}" 
                                                           Height="{Binding ActualHeight, ElementName=dropDownBorder}" 
                                                           Width="{Binding ActualWidth, ElementName=dropDownBorder}"/>
                                            </Canvas>
                                            <ItemsPresenter x:Name="ItemsPresenter" 
                                                            KeyboardNavigation.DirectionalNavigation="Contained" 
                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#71717a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            
            <!-- Estilo para los ítems dentro de este ComboBox -->
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#fafafa"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" 
                                        Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        Padding="{TemplateBinding Padding}" 
                                        SnapsToDevicePixels="true">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter TargetName="Bd" Property="Background" Value="#3f3f46"/>
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="true">
                                        <Setter TargetName="Bd" Property="Background" Value="#312e81"/>
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <!-- Borde Principal con esquinas redondeadas y sombra -->
    <Border CornerRadius="16" Background="#0c0a09" BorderBrush="#292524" BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Color="Black" Opacity="0.6" Direction="270" ShadowDepth="5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Barra de título -->
                <RowDefinition Height="45"/>
                <!-- Contenido -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. BARRA DE TÍTULO PERSONALIZADA -->
            <Grid Grid.Row="0" x:Name="TitleBar" Background="#1c1917" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icono de la App -->
                <Path Data="M12,2A3,3 0 0,0 9,5V11A3,3 0 0,0 12,14A3,3 0 0,0 15,11V5A3,3 0 0,0 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" 
                      Fill="#6366f1" Stretch="Uniform" Width="18" Height="18" Margin="15,0,5,0" VerticalAlignment="Center"/>

                <!-- Título -->
                <TextBlock Grid.Column="1" Text="Grabador de Audio Pro" Foreground="#e7e5e4" FontWeight="Bold" 
                           FontSize="13" VerticalAlignment="Center" Margin="5,0,0,0"/>

                <!-- Controles de la Ventana (macOS style traffic lights) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <!-- Acerca de -->
                    <Button Width="14" Height="14" Margin="0,0,12,0" Click="AboutButton_Click" Cursor="Hand" ToolTip="Acerca de">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse x:Name="circle" Fill="Transparent"/>
                                    <Path x:Name="icon" Data="M11,9H13V7H11M12,20C7.58,20 4,16.42 4,12C4,7.58 7.58,4 12,4C16.42,4 20,7.58 20,12C20,16.42 16.42,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="#a1a1aa" Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="icon" Property="Fill" Value="#fafafa"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Configuración -->
                    <Button Width="14" Height="14" Margin="0,0,12,0" Click="SettingsButton_Click" Cursor="Hand" ToolTip="Configuración">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse x:Name="circle" Fill="Transparent"/>
                                    <Path x:Name="icon" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="#a1a1aa" Stretch="Uniform"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="icon" Property="Fill" Value="#fafafa"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Minimizar -->
                    <Button Width="12" Height="12" Margin="0,0,8,0" Click="MinimizeButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="circle" Fill="#eab308"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#ca8a04"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Cerrar -->
                    <Button Width="12" Height="12" Click="CloseButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="circle" Fill="#ef4444"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#dc2626"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. CONTENIDO PRINCIPAL -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Historial (Izquierda) -->
                    <ColumnDefinition Width="320"/>
                    <!-- Controladores (Derecha) -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- A. PANEL LATERAL: HISTORIAL DE GRABACIONES -->
                <Border Grid.Column="0" Background="#141417" BorderBrush="#1c1917" BorderThickness="0,0,1.5,0" CornerRadius="0,0,0,16">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Título de sección -->
                        <TextBlock Grid.Row="0" Text="Historial de Sesión" Foreground="#fafafa" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                        <!-- Lista de archivos -->
                        <ListBox Grid.Row="1" x:Name="RecordingsListBox" Background="Transparent" BorderThickness="0" 
                                 ItemContainerStyle="{StaticResource RecordItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="RecordingsListBox_SelectionChanged">
                            <ListBox.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent" />
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Icono -->
                                        <Path Grid.Column="0" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                              Fill="#a1a1aa" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        
                                        <!-- Detalles del archivo -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" Foreground="#fafafa" FontWeight="Medium" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Details}" Foreground="#a1a1aa" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Controles del historial -->
                        <StackPanel Grid.Row="2" Margin="0,15,0,0">
                            <!-- Botón Reproducir Seleccionado -->
                            <Button x:Name="PlaySelectedButton" Content="Reproducir Selección" Style="{StaticResource ModernButton}" 
                                    Margin="0,0,0,8" Click="PlaySelectedButton_Click" IsEnabled="False"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="StopPlayButton" Content="Detener Audio" Style="{StaticResource SecondaryButton}" 
                                        Margin="0,0,4,0" Click="StopPlayButton_Click" IsEnabled="False"/>
                                <Button Grid.Column="1" x:Name="OpenFolderButton" Content="Abrir Carpeta" Style="{StaticResource SecondaryButton}" 
                                        Margin="4,0,0,0" Click="OpenFolderButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- B. PANEL DE CONTROL (DERECHA) -->
                <Grid Grid.Column="1" Margin="25">
                    <Grid.RowDefinitions>
                        <!-- Info Grabadora -->
                        <RowDefinition Height="Auto"/>
                        <!-- Ajustes rápidos -->
                        <RowDefinition Height="Auto"/>
                        <!-- Medidores y Temporizador -->
                        <RowDefinition Height="*"/>
                        <!-- Botones de Acción -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Info Grabadora -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Panel de Control" Foreground="#fafafa" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Graba y mezcla el micrófono y el sonido del sistema en WAV o MP3" Foreground="#a1a1aa" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Ajustes Rápidos -->
                    <Border Grid.Row="1" Background="#141415" BorderBrush="#27272a" BorderThickness="1" CornerRadius="12" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Selección de Entradas -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Grabación de Micrófono -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox x:Name="MicCheckBox" IsChecked="True" VerticalAlignment="Center" Checked="SourceCheckBox_Changed" Unchecked="SourceCheckBox_Changed"/>
                                    <TextBlock Text="Grabar Micrófono:" Foreground="#fafafa" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Selector de Dispositivo -->
                                <ComboBox Grid.Column="2" x:Name="MicComboBox" Style="{StaticResource DarkComboBox}" Height="30" />
                            </Grid>

                             <!-- Separador -->
                             <Separator Grid.Row="1" Background="#27272a" Margin="0,8"/>

                             <!-- Otras configuraciones (Sistema, Formato y Destino) -->
                             <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Fila 1: Grabación de PC y Formato -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Grabación de PC -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox x:Name="SystemAudioCheckBox" IsChecked="True" VerticalAlignment="Center" Checked="SourceCheckBox_Changed" Unchecked="SourceCheckBox_Changed"/>
                                        <TextBlock Text="Grabar Audio del Sistema (PC / Altavoces)" Foreground="#fafafa" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Formato -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Formato:" Foreground="#fafafa" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="Mp3Radio" Content="MP3" IsChecked="True" Foreground="#fafafa" Margin="0,0,10,0" VerticalAlignment="Center" Cursor="Hand"/>
                                        <RadioButton x:Name="WavRadio" Content="WAV" Foreground="#fafafa" VerticalAlignment="Center" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Fila 2: Etiqueta de la sesión -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Etiqueta (opcional):" Foreground="#a1a1aa" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" x:Name="LabelTextBox" Background="#1c1c1f" Foreground="#fafafa" BorderBrush="#27272a" 
                                             BorderThickness="1" Padding="8,4" Height="28" VerticalContentAlignment="Center" CaretBrush="White"
                                             ToolTip="Ingresa una etiqueta para nombrar la carpeta, grabaciones y capturas"/>
                                </Grid>

                                <!-- Fila 3: Captura de Ventana -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Capturar:" Foreground="#a1a1aa" FontSize="11" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="2" x:Name="WindowCaptureComboBox" Style="{StaticResource DarkComboBox}" Height="30"
                                              DropDownOpened="WindowCaptureComboBox_DropDownOpened"
                                              ToolTip="Selecciona la ventana específica para las capturas de pantalla o 'Pantalla completa'"/>
                                </Grid>

                                <!-- Fila 4: Carpeta de Destino -->
                                <Grid Grid.Row="6">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="10"/>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="10"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Carpeta de salida:" Foreground="#a1a1aa" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" x:Name="OutputFolderTextBox" Background="#1c1c1f" Foreground="#fafafa" BorderBrush="#27272a" 
                                             BorderThickness="1" Padding="8,4" Height="28" IsReadOnly="True" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="4" x:Name="BrowseButton" Content="Examinar..." Style="{StaticResource SecondaryButton}" 
                                             Padding="10,0" Height="28" Click="BrowseButton_Click"/>
                                </Grid>
                             </Grid>
                         </Grid>
                    </Border>

                    <!-- Medidores y Temporizador -->
                    <Grid Grid.Row="2" Margin="0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Medidores (Izquierda) -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                            <!-- Medidor de Micrófono -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Nivel de Micrófono" Foreground="#a1a1aa" FontSize="11"/>
                                    <TextBlock x:Name="MicLevelText" Text="0%" Foreground="#6366f1" FontSize="11" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                                <ProgressBar x:Name="MicVolumeMeter" Style="{StaticResource VolumeProgressBar}" Value="0" Maximum="100" Margin="0,0,0,6"/>
                                <Grid>
                                    <TextBlock Text="Ganancia Micrófono" Foreground="#71717a" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="MicVolumeSliderText" Text="100%" Foreground="#fafafa" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="MicVolumeSlider" Style="{StaticResource ModernSlider}" Foreground="#6366f1" Minimum="0" Maximum="2" Value="1" Margin="0,2,0,0" ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>

                            <!-- Medidor de Sistema -->
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Nivel de Audio del Sistema (PC)" Foreground="#a1a1aa" FontSize="11"/>
                                    <TextBlock x:Name="SysLevelText" Text="0%" Foreground="#ec4899" FontSize="11" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                                <ProgressBar x:Name="SysVolumeMeter" Style="{StaticResource VolumeProgressBar}" Value="0" Maximum="100" Margin="0,0,0,6"/>
                                <Grid>
                                    <TextBlock Text="Volumen Sistema" Foreground="#71717a" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SysVolumeSliderText" Text="70%" Foreground="#fafafa" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="SysVolumeSlider" Style="{StaticResource ModernSlider}" Foreground="#ec4899" Minimum="0" Maximum="1" Value="0.7" Margin="0,2,0,0" ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Temporizador (Derecha) -->
                        <Border Grid.Column="1" Background="#141415" BorderBrush="#27272a" BorderThickness="1" CornerRadius="12" Padding="15" Height="100" VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="TIEMPO DE GRABACIÓN" Foreground="#71717a" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TimerText" Text="00:00:00" Foreground="#fafafa" FontSize="32" FontFamily="Consolas" FontWeight="Light" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Botones de Acción (Abajo) -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Texto de Estado -->
                        <TextBlock Grid.Column="0" x:Name="StatusText" Text="Listo para grabar" Foreground="#a1a1aa" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>

                        <!-- Botón Grabar / Pausar -->
                        <Button Grid.Column="1" x:Name="RecordBtn" Style="{StaticResource RecordButton}" Click="RecordBtn_Click">
                            <!-- Icono Grabar (Círculo blanco o similar) -->
                            <Path x:Name="RecordBtnIcon" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" 
                                  Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                        </Button>

                        <!-- Botón Detener -->
                        <Button Grid.Column="3" x:Name="StopBtn" Click="StopBtn_Click" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="circle" Fill="#27272a" Width="48" Height="48"/>
                                        <!-- Icono Detener (Cuadrado) -->
                                        <Path Data="M18,18H6V6H18V18Z" Fill="White" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#3f3f46"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#52525b"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="circle" Property="Fill" Value="#18181b"/>
                                            <Setter Property="Foreground" Value="#52525b"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
            
            <!-- Notificación de Captura de Pantalla -->
            <Border x:Name="ScreenshotNotification" Background="#4f46e5" CornerRadius="8" Padding="15,10" 
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30" 
                    IsHitTestVisible="False" Opacity="0">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M21,17H3V5H21M21,3H3C1.9,3 1,3.9 1,5V17C1,18.1 1.9,19 3,19H8V21H16V19H21C22.1,19 23,18.1 23,17V5C23,3.9 22.1,3 21,3Z" Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock Text="¡Captura de pantalla guardada!" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
        </Grid>
    </Border>
</Window>
